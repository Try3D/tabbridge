{
  "manifest_version": 3,
  "name": "TabSync",
  "version": "1.1.0",
  "description": "Share your open tabs across devices",
  "permissions": ["tabs", "storage", "windows"],
  "host_permissions": [
    "https://*.workers.dev/*",
    "https://tabbridge.pages.dev/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabSync"
  },
  "background": {
    "service_worker": "background.js"
  }
}
